{
  "name": "0xkobold",
  "version": "0.1.0",
  "description": "Your digital familiar - a personal AI assistant that learns and evolves",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "bin": {
    "0xkobold": "./dist/src/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "bun run src/index.ts",
    "cli": "bun run src/cli/index.ts",
    "tui": "bun run src/index.ts",
    "init": "bun run src/cli/index.ts init",
    "test": "bun test",
    "update": "bun run src/cli/index.ts update",
    "update:check": "bun run src/cli/index.ts update check",
    "update:install": "bun run src/cli/index.ts update install",
    "update:framework": "bun run src/cli/index.ts update framework",
    "setup-hooks": "bash scripts/install-hooks.sh",
    "prepublishOnly": "bun run build",
    "postinstall": "node scripts/postinstall.js || echo 'Welcome to 0xKobold! Run: 0xkobold setup'"
  },
  "keywords": ["ai", "assistant", "cli", "agent", "kobold"],
  "author": "0xKobold Team",
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-agent-core": "0.57.1",
    "@mariozechner/pi-coding-agent": "0.57.1",
    "@mariozechner/pi-tui": "0.57.1",
    "ajv": "^8.18.0",
    "blessed": "^0.1.81",
    "commander": "^11.1.0",
    "discord.js": "^14.25.1",
    "glob": "^10.5.0",
    "json5": "^2.2.3",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "sharp": "^0.33.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/json5": "^2.2.0",
    "@types/node": "^20.19.35",
    "bun-types": "latest",
    "typescript": "^5.9.3",
    "@types/bun": "latest"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.7",
  "private": false,
  "files": [
    "dist",
    "scripts/postinstall.js",
    "README.md",
    "LICENSE",
    "package.json",
    "USAGE.md",
    "HEARTBEAT.md",
    "skills/",
    ".agents/skills/"
  ],
  "publishConfig": {
    "access": "public"
  }
}
