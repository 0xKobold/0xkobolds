{
  "name": "0xkobold",
  "version": "0.6.11",
  "description": "Your digital familiar - Koclaw-style gateway, session management, and multi-agent orchestration",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "bin": {
    "0xkobold": "dist/src/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist/",
    "build": "tsc",
    "build:clean": "npm run clean && npm run build",
    "dev": "tsc --watch",
    "start": "bun run src/index.ts",
    "cli": "bun run src/cli/index.ts",
    "tui": "bun run src/index.ts",
    "init": "bun run src/cli/index.ts init",
    "test": "bun test",
    "update": "bun run src/cli/index.ts update",
    "update:check": "bun run src/cli/index.ts update check",
    "update:install": "bun run src/cli/index.ts update install",
    "update:framework": "bun run src/cli/index.ts update framework",
    "setup-hooks": "bash scripts/install-hooks.sh",
    "prepublishOnly": "npm run clean && npm run build",
    "postinstall": "node scripts/postinstall.js && node scripts/link-pi-extensions.js || echo 'Welcome to 0xKobold! Run: 0xkobold setup'"
  },
  "keywords": [
    "ai",
    "assistant",
    "cli",
    "agent",
    "kobold"
  ],
  "author": "0xKobold Team",
  "license": "MIT",
  "dependencies": {
    "@0xkobold/pi-ollama": "^0.1.3",
    "@aliou/pi-processes": "^0.6.2",
    "@mariozechner/pi-agent-core": "0.57.1",
    "@mariozechner/pi-coding-agent": "0.57.1",
    "@mariozechner/pi-tui": "0.57.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "ajv": "^8.18.0",
    "blessed": "^0.1.81",
    "commander": "^11.1.0",
    "discord.js": "^14.25.1",
    "glob": "^10.5.0",
    "json5": "^2.2.3",
    "node-machine-id": "^1.1.12",
    "node-telegram-bot-api": "^0.67.0",
    "pi-extmgr": "^0.1.25",
    "pi-librarian": "^1.3.0",
    "pi-memory-md": "^0.1.1",
    "pi-messenger": "^0.13.0",
    "pi-subagents": "^0.11.2",
    "pi-web-access": "^0.10.3",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "sharp": "^0.33.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/bun": "latest",
    "@types/json5": "^2.2.0",
    "@types/node": "^20.19.35",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.7",
  "private": false,
  "files": [
    "dist",
    "scripts/migrate-from-openclaw.sh",
    "scripts/postinstall.js",
    "README.md",
    "LICENSE",
    "package.json",
    "SOUL.md",
    "IDENTITY.md",
    "HEARTBEAT.md",
    "skills/",
    ".agents/skills/"
  ],
  "publishConfig": {
    "access": "public"
  }
}
