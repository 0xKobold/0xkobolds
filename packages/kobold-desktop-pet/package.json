    "@types/node": "^20.10.0",
    "@types/three": "^0.183.1",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  },
  "optionalDependencies": {
    "vrm-mixamo-retarget": "^1.0.0"
  }
}