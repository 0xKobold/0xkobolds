{
  "name": "kobold-desktop-familiar",
  "version": "1.0.0",
  "description": "Kobold Familiar - Embodied AI interface using VRM avatar with Mixamo animations",
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "web": "bunx serve -p 8080",
